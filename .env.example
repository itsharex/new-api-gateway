# ── new-api-gateway 配置 ──────────────────────────────
# 复制为 .env.local 后填入实际值：
#   cp .env.example .env.local

# ── 必填 ──────────────────────────────────────────────
# 上游 new-api 地址（详见 README "Docker 网络拓扑" 章节）
# 同机 Docker 部署:   http://host.docker.internal:3000
# 跨机 Docker 部署:   http://<new-api内网IP>:3000
# 本地开发:           http://localhost:3000
NEW_API_BASE_URL=http://localhost:3000

# HMAC 签名密钥（≥32 字符随机字符串）
AUDIT_HMAC_SECRET=replace-with-at-least-32-random-characters

# new-api 数据库 DSN（身份解析用）
# 同机 Docker 部署:   postgres://root:123456@host.docker.internal:5432/new-api?sslmode=disable
# 跨机 Docker 部署:   postgres://root:123456@<new-api内网IP>:5432/new-api?sslmode=disable
# 本地开发:           localhost:5433（new-api 默认映射端口）
NEW_API_POSTGRES_DSN=postgres://root:123456@localhost:5433/new-api?sslmode=disable

# ── 可选 ──────────────────────────────────────────────
# 网关监听地址（默认 :8080）
AUDIT_GATEWAY_LISTEN_ADDR=:8080

# 证据存储后端：filesystem（默认）或 oss
EVIDENCE_STORAGE_BACKEND=filesystem

# 证据存储目录（本地开发用）
EVIDENCE_STORAGE_DIR=./var/evidence

# 证据存储宿主机目录（Docker 部署用，挂载到容器 /evidence）
EVIDENCE_HOST_DIR=./var/evidence

# 审计网关数据库 DSN（本地开发用，Docker 部署使用 compose 内部默认值）
POSTGRES_DSN=postgres://audit:audit@localhost:5432/audit_gateway?sslmode=disable

# Redis 地址（本地开发用，Docker 部署使用 compose 内部默认值）
REDIS_ADDR=localhost:6379

# ── Embedding 服务 ─────────────────────────────────────
# 使用本地构建的 Python embedding 服务（FastAPI + sentence-transformers）
# Docker Compose 默认使用代码中的 BAAI/bge-m3，并缓存到 embedding-model-cache volume
# 如需配置 HF_ENDPOINT 或 EMBEDDING_MODEL，请在 embedding 服务 environment 或 compose override 中显式添加

# ── Analysis Worker ─────────────────────────────────────
# pip index 冲突解决策略（默认 unsafe-best-match）
# UV_INDEX_STRATEGY=unsafe-best-match

# ── OSS 后端（EVIDENCE_STORAGE_BACKEND=oss 时必填）──
# OSS_ENDPOINT=oss-cn-shenzhen.aliyuncs.com
# OSS_BUCKET=your-bucket
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
